# Solana token mint (optional override; default is set in src/config.ts)
# VITE_TOKEN_MINT=

# Optional: your coin’s Pump.fun page
# VITE_PUMP_FUN_URL=https://pump.fun/coin/...

# Footer X profile link
# VITE_FOOTER_X_URL=https://x.com/yourhandle

# Hero “CA: …” override (defaults to mint)
# VITE_CA_DISPLAY=
