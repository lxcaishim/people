# Solana token mint (optional override; default is set in src/config.ts)
# VITE_TOKEN_MINT=

# Optional: your coin's Pump.fun page
# VITE_PUMP_FUN_URL=https://pump.fun/coin/...

# Footer X profile link
# VITE_FOOTER_X_URL=https://x.com/yourhandle

# Hero "CA: …" override (defaults to mint)
# VITE_CA_DISPLAY=

# Supabase for "Our people" visitor database (recommended)
# 1. Create a project at supabase.com
# 2. Run supabase-setup.sql in the SQL Editor
# 3. Copy your project URL and anon key from Settings > API
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
